{
  "expo": {
    "name": "CareHQ",
    "slug": "carehq",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "carehq",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0A7B6E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.carehq.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A7B6E"
      },
      "package": "com.carehq.app",
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "34acfccf-7bb0-4ed4-b9a3-4c9604903a78"
      }
    },
    "owner": "d2bishop"
  }
}
